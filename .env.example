# === MCP Server ===
MCP_SERVER_NAME=salesforce-netsuite
MCP_TRANSPORT=sse
MCP_HOST=0.0.0.0
MCP_PORT=8000

# === Salesforce (OAuth 2.0 Refresh Token) ===
SF_CLIENT_ID=your_connected_app_client_id
SF_CLIENT_SECRET=your_connected_app_client_secret
# Set to "test" for sandbox, leave empty for production
SF_DOMAIN=

# === NetSuite (TBA — OAuth 1.0) ===
NETSUITE_ACCOUNT_ID=YOUR_ACCOUNT_ID
NETSUITE_TBA__CONSUMER_KEY=your_consumer_key
NETSUITE_TBA__CONSUMER_SECRET=your_consumer_secret
NETSUITE_TBA__TOKEN_KEY=your_token_key
NETSUITE_TBA__TOKEN_SECRET=your_token_secret

# === Pardot / Account Engagement (uses Salesforce OAuth) ===
PARDOT_BUSINESS_UNIT_ID=your_pardot_business_unit_id
